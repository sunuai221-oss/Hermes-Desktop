{
  "name": "hermes-desktop",
  "productName": "Hermes Desktop",
  "description": "Windows-first Electron desktop application for operating a Hermes runtime hosted in WSL.",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "homepage": "https://github.com/sunuai221-oss/Hermes-Desktop#readme",
  "bugs": {
    "url": "https://github.com/sunuai221-oss/Hermes-Desktop/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sunuai221-oss/Hermes-Desktop.git"
  },
  "keywords": [
    "electron",
    "react",
    "vite",
    "windows",
    "wsl",
    "hermes"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "setup": "npm install && npm run install:server",
    "install:server": "npm --prefix server install",
    "check": "npm run lint && npm run test && npm run build",
    "dev": "node server/index.mjs --dev",
    "dev:vite": "vite --port 3030",
    "server": "node server/index.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "node --test --experimental-test-isolation=none server/tests/*.test.mjs",
    "preview": "vite preview",
    "desktop": "electron .",
    "desktop:dev": "node electron/launch-dev.mjs",
    "desktop:smoke": "node scripts/desktop-smoke.mjs",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:build": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "axios": "^1.14.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.9.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  },
  "build": {
    "appId": "local.hermes.desktop",
    "productName": "Hermes Desktop",
    "icon": "build/icons/hermes.ico",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icons/hermes.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "Hermes-Desktop-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Hermes Desktop"
    }
  }
}
